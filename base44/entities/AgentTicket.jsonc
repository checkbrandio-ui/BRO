{
  "name": "AgentTicket",
  "type": "object",
  "properties": {
    "question": {
      "type": "string",
      "description": "\u0412\u043e\u043f\u0440\u043e\u0441 \u0438\u043b\u0438 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430, \u0442\u0440\u0435\u0431\u0443\u044e\u0449\u0430\u044f \u043e\u0442\u0432\u0435\u0442\u0430 \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440\u0430"
    },
    "asked_by_name": {
      "type": "string",
      "description": "\u0418\u043c\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f, \u0437\u0430\u0434\u0430\u0432\u0448\u0435\u0433\u043e \u0432\u043e\u043f\u0440\u043e\u0441"
    },
    "asked_by_role": {
      "type": "string",
      "description": "\u0420\u043e\u043b\u044c: admin / agency / manager"
    },
    "category": {
      "type": "string",
      "description": "\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f \u0432\u043e\u043f\u0440\u043e\u0441\u0430 (CRM, \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u044b, \u043b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0430, \u0434\u0440\u0443\u0433\u043e\u0435)"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium",
      "description": "\u041f\u0440\u0438\u043e\u0440\u0438\u0442\u0435\u0442 \u0442\u0438\u043a\u0435\u0442\u0430"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "answered",
        "closed"
      ],
      "default": "open",
      "description": "\u0421\u0442\u0430\u0442\u0443\u0441 \u0442\u0438\u043a\u0435\u0442\u0430"
    },
    "answer": {
      "type": "string",
      "description": "\u041e\u0442\u0432\u0435\u0442 \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440\u0430"
    },
    "answered_by": {
      "type": "string",
      "description": "\u041a\u0442\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u043b"
    },
    "conversation_id": {
      "type": "string",
      "description": "ID \u0434\u0438\u0430\u043b\u043e\u0433\u0430 \u0441 \u0430\u0433\u0435\u043d\u0442\u043e\u043c, \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u043e\u0433\u043e \u0441\u043e\u0437\u0434\u0430\u043d \u0442\u0438\u043a\u0435\u0442"
    }
  },
  "required": [
    "question",
    "status"
  ]
}