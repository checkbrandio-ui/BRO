{
  "name": "City",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0433\u043e\u0440\u043e\u0434\u0430"
    },
    "region": {
      "type": "string",
      "description": "\u0420\u0435\u0433\u0438\u043e\u043d / \u0441\u0443\u0431\u044a\u0435\u043a\u0442 \u0420\u0424"
    },
    "lat": {
      "type": "number",
      "description": "\u0428\u0438\u0440\u043e\u0442\u0430"
    },
    "lon": {
      "type": "number",
      "description": "\u0414\u043e\u043b\u0433\u043e\u0442\u0430"
    },
    "source": {
      "type": "string",
      "enum": [
        "nominatim",
        "llm",
        "manual"
      ],
      "default": "nominatim",
      "description": "\u0418\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442"
    },
    "is_assembly_point": {
      "type": "boolean",
      "default": false,
      "description": "\u0413\u043e\u0440\u043e\u0434 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0439 \u0442\u043e\u0447\u043a\u043e\u0439 \u0441\u0431\u043e\u0440\u0430"
    },
    "payment_amount": {
      "type": "number",
      "description": "\u0412\u044b\u043f\u043b\u0430\u0442\u0430 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u0443 (\u0440\u0443\u0431.)"
    },
    "previous_payment": {
      "type": "number",
      "description": "\u041f\u0440\u0435\u0434\u044b\u0434\u0443\u0449\u0430\u044f \u0432\u044b\u043f\u043b\u0430\u0442\u0430 (\u0440\u0443\u0431., \u043d\u0435\u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e)"
    },
    "processing_time": {
      "type": "string",
      "description": "\u0412\u0440\u0435\u043c\u044f \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u044f (\u043d\u0430\u043f\u0440. \u00ab1 \u0434\u0435\u043d\u044c\u00bb, \u00ab1\u20132 \u0434\u043d\u044f\u00bb)"
    },
    "agent_fee": {
      "type": "number",
      "description": "\u041e\u043f\u043b\u0430\u0442\u0430 \u0430\u0433\u0435\u043d\u0442\u0443 \u0437\u0430 \u0442\u0440\u0443\u0434\u043e\u0443\u0441\u0442\u0440\u043e\u0435\u043d\u043d\u043e\u0433\u043e \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u0430 (\u0440\u0443\u0431.)"
    },
    "curator_name": {
      "type": "string",
      "description": "\u0424\u0418\u041e \u043a\u0443\u0440\u0430\u0442\u043e\u0440\u0430 \u0442\u043e\u0447\u043a\u0438 \u0441\u0431\u043e\u0440\u0430"
    },
    "curator_phone": {
      "type": "string",
      "description": "\u0422\u0435\u043b\u0435\u0444\u043e\u043d \u043a\u0443\u0440\u0430\u0442\u043e\u0440\u0430 \u0442\u043e\u0447\u043a\u0438 \u0441\u0431\u043e\u0440\u0430"
    }
  },
  "required": [
    "name"
  ]
}