    {
      "function_name": "getCrmContext",
      "description": "\u041f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442 CRM: \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b, FAQ, \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044e, \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0443, \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432 \u0431\u0435\u0437 \u043f\u0443\u043d\u043a\u0442\u0430 \u0441\u0431\u043e\u0440\u0430, \u043d\u043e\u0432\u044b\u0435 \u0433\u043e\u0440\u043e\u0434\u0430, \u0442\u0438\u043a\u0435\u0442\u044b, \u0441\u043f\u0438\u0441\u043e\u043a \u0442\u043e\u0447\u0435\u043a \u0441\u0431\u043e\u0440\u0430"
    },
    {
      "function_name": "findNearestCity",
      "description": "\u041d\u0430\u0439\u0442\u0438 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0435 \u0433\u043e\u0440\u043e\u0434\u0430 \u0438\u0437 \u0441\u043f\u0440\u0430\u0432\u043e\u0447\u043d\u0438\u043a\u0430 \u043a \u0443\u043a\u0430\u0437\u0430\u043d\u043d\u043e\u043c\u0443 \u0433\u043e\u0440\u043e\u0434\u0443 \u043f\u043e \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u0430\u043c (\u0444\u043e\u0440\u043c\u0443\u043b\u0430 \u0413\u0430\u0432\u0435\u0440\u0441\u0438\u043d\u0443\u0441\u0430)"
    },
    {
      "function_name": "syncAssemblyPoints",
      "description": "\u041d\u0430\u0439\u0442\u0438 \u043d\u043e\u0432\u044b\u0435 \u0433\u043e\u0440\u043e\u0434\u0430 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432, \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u044b \u0447\u0435\u0440\u0435\u0437 \u0432\u0435\u0431-\u043f\u043e\u0438\u0441\u043a, \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u0432 \u0441\u043f\u0440\u0430\u0432\u043e\u0447\u043d\u0438\u043a \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u043f\u0438\u0441\u043e\u043a \u0442\u043e\u0447\u0435\u043a \u0441\u0431\u043e\u0440\u0430. \u0422\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440\u043e\u0432."
    }
