# PostgreSQL — одна строка подключения
DATABASE_URL=postgresql://appuser:PASSWORD@localhost:5432/appdb

# Опционально: включить SSL для managed Postgres (Render, Supabase и т.д.)
DATABASE_SSL=false

# JWT секрет — сгенерировать: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_change_me

# Порт сервера
PORT=3000
